{
  "name": "suwol-pixel-studio",
  "productName": "Suwol Pixel Studio",
  "version": "0.5.0",
  "description": "A secure, modern desktop workspace for pixel art creation.",
  "author": "Suwol Pixel Studio contributors",
  "license": "MIT",
  "private": true,
  "main": ".vite/build/main.js",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "electron-forge start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "pnpm plugin:pack && cross-env SUWOL_E2E_BUILD=1 pnpm package && playwright test",
    "benchmark:m2": "vite-node scripts/benchmark-m2.ts",
    "benchmark:m3": "vite-node scripts/benchmark-m3.ts",
    "benchmark:m5": "vite-node scripts/benchmark-m5.ts",
    "benchmark": "pnpm benchmark:m5",
    "plugin:validate": "vite-node scripts/plugin-validate.ts",
    "plugin:pack": "vite-node scripts/plugin-pack.ts",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@suwol/command-system": "workspace:0.0.0",
    "@suwol/editor-core": "workspace:0.0.0",
    "@suwol/file-format": "workspace:0.0.0",
    "@suwol/pixel-renderer": "workspace:0.0.0",
    "@suwol/plugin-api": "workspace:1.1.0",
    "@suwol/plugin-host": "workspace:0.5.0",
    "@suwol/shared": "workspace:0.0.0",
    "@suwol/ui": "workspace:0.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "fast-png": "8.0.0",
    "fflate": "0.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cross-env": "10.1.0",
    "electron": "43.1.0",
    "eslint": "10.6.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vite-node": "6.0.0",
    "vitest": "4.1.10"
  }
}
