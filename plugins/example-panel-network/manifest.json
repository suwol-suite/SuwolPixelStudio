{
  "manifestVersion": 1,
  "id": "studio.suwol.example-panel-network",
  "name": "Local Pixel Generator",
  "version": "0.1.0",
  "apiVersion": "^1.0.0",
  "engines": { "suwolPixelStudio": ">=0.4.0" },
  "entry": "dist/main.js",
  "publisher": "Suwol Pixel Studio",
  "description": "Calls an approved localhost RGBA endpoint from a sandboxed panel and inserts the result transactionally.",
  "permissions": [
    "document.read",
    "document.write",
    "selection.read",
    "ui.panel",
    "ui.notification",
    "storage",
    "network:localhost"
  ],
  "contributes": {
    "panels": [
      {
        "id": "studio.suwol.example-panel-network.panel",
        "title": "Local Pixel Generator",
        "entry": "dist/panel/index.html"
      }
    ]
  }
}
